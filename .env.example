# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Data Sources ─────────────────────────────────────────────────────────────
DEFILLAMA_BASE=https://api.llama.fi   # public API, no key needed

# ─── Research Settings ───────────────────────────────────────────────────────
MIN_TVL_USD=1000000            # skip protocols below $1M TVL
MAX_PROTOCOLS_PER_RUN=10       # cap per research cycle

# ─── Schedule ────────────────────────────────────────────────────────────────
REFRESH_INTERVAL_MS=86400000   # refresh daily

# ─── Model ───────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
